# ─────────────────────────────────────────────────────────────
# iRemainder — environment variables
# Copy this file to `.env` and fill in real values.
# ─────────────────────────────────────────────────────────────

# SQLite database file (created automatically on first migrate).
DATABASE_URL="file:./dev.db"

# ── Authentication ───────────────────────────────────────────
# The shared operator password is never stored in plaintext.
# Instead we store its SHA-256 hash. Generate it once with:
#
#   node -e "import('node:crypto').then(c => console.log(c.createHash('sha256').update('YOUR_PASSWORD').digest('hex')))"
#
# Example: for the password "admin123" the hash is
#   240be518fabd2724ddb6f04eeb1da5967448d7e831c08c8fa822809f74c720a9
#
# The operator logs in by typing YOUR_PASSWORD; the server hashes
# their input and compares to OPERATOR_PASSWORD_HASH.
OPERATOR_PASSWORD_HASH="240be518fabd2724ddb6f04eeb1da5967448d7e831c08c8fa822809f74c720a9"

# Secret used to sign the session cookie (iron-session).
# Generate with:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="change-me-to-a-long-random-hex-string-at-least-32-bytes"
